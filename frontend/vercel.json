{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://myschedule-api.onrender.com/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
