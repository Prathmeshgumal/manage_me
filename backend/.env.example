# Supabase: pooled connection (port 6543) for the running app
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase: direct connection (port 5432) used only for Prisma migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
PORT=4000

# GitHub App integration (optional — see README "GitHub integration")
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/github/callback
GITHUB_TOKEN_ENC_KEY=
GITHUB_STATE_SECRET=
FRONTEND_URL=http://localhost:5173
